{
    "github": {
        "enabled": true,
        "silent": true
    },
    "rewrites": [
        {
            "source": "/",
            "destination": "/index.html"
        },
        {
            "source": "/club",
            "destination": "/index.html"
        },
        {
            "source": "/club/:path*",
            "destination": "/index.html"
        }
    ]
}